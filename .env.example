# =============================================================================
# CareerLens -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Placeholders (replaced during /make-it build phase):
#   CareerLens          - human-readable app name
#   career-lens          - kebab-case app name
#   3300     - host port for frontend (e.g., 3100)
#   8300      - host port for backend (e.g., 8100)
#   5600           - host port for PostgreSQL (e.g., 5500)
#   10190    - host port for mock-oidc (e.g., 10190)
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://career-lens:career-lens@localhost:5600/career-lens

# ---------------------------------------------------------------------------
# OIDC Authentication
# ---------------------------------------------------------------------------
# For local development, these point to the mock-oidc container.
# For production, replace with your Azure AD / Entra ID values.
OIDC_ISSUER_URL=http://localhost:10190
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3300
BACKEND_URL=http://localhost:8300

# ---------------------------------------------------------------------------
# AI Provider Configuration
# ---------------------------------------------------------------------------
# Which provider is active: anthropic_foundry, anthropic, openai, ollama
AI_PROVIDER=anthropic_foundry

# Azure AI Foundry (when AI_PROVIDER=anthropic_foundry)
# Supports API key or DefaultAzureCredential (fallback when no key set)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
ANTHROPIC_FOUNDRY_MODEL_HEAVY=cogdep-aifoundry-dev-eus2-claude-opus-4-6
ANTHROPIC_FOUNDRY_MODEL_STANDARD=cogdep-aifoundry-dev-eus2-claude-sonnet-4-5
ANTHROPIC_FOUNDRY_MODEL_LIGHT=cogdep-aifoundry-dev-eus2-claude-haiku-4-5

# Direct Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HEAVY=claude-opus-4-6
ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-5
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL_HEAVY=gpt-4o
OPENAI_MODEL_STANDARD=gpt-4o-mini
OPENAI_MODEL_LIGHT=gpt-4o-mini

# Ollama (when AI_PROVIDER=ollama -- local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_HEAVY=llama3.1:70b
OLLAMA_MODEL_STANDARD=llama3.1:8b
OLLAMA_MODEL_LIGHT=llama3.1:8b

# ---------------------------------------------------------------------------
# RAG / Embedding Configuration
# ---------------------------------------------------------------------------
# "openai" requires OPENAI_API_KEY; "keyword" uses BM25-style matching (no API needed)
EMBEDDING_PROVIDER=keyword
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=10

# ---------------------------------------------------------------------------
# Mock Olivia (Paradox.ai chatbot -- local dev only)
# ---------------------------------------------------------------------------
MOCK_OLIVIA_URL=http://localhost:10191

# Secret enforcement (only set to true in actual production)
ENFORCE_SECRETS=false
